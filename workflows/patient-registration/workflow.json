{
  "_type": "workflow",
  "_version": 1,
  "slug": "patient-registration",
  "name": "Patient Registration",
  "description": "Reads patient registration form fields from a dental practice page and stores them in the demo database via n8n",
  "workflow_type": "tool",
  "category_name": "automation",
  "llm_model_name": null,
  "stt_model_name": null,
  "tool_name": "Patient Registration \u2192 Ancroo",
  "output_action": "notification",
  "demo_url": "patient-registration/demo.html",
  "timeout_seconds": 60,
  "recipe": {
    "collect": ["form_fields", "page_context"],
    "form_fields": [
      {"name": "nachname",         "selector": "input[name='nachname'], input[name='last_name'], #field-nachname"},
      {"name": "vorname",          "selector": "input[name='vorname'], input[name='first_name'], #field-vorname"},
      {"name": "geburtsdatum",     "selector": "input[name='geburtsdatum'], input[type='date'], #field-geburtsdatum"},
      {"name": "versicherung",     "selector": "select[name='versicherung'], #field-versicherung"},
      {"name": "telefon",          "selector": "input[name='telefon'], input[type='tel'], #field-telefon"},
      {"name": "beschwerden",      "selector": "textarea[name='beschwerden'], #field-beschwerden"},
      {"name": "vorerkrankungen",  "selector": "input[name='vorerkrankungen'], #field-vorerkrankungen"}
    ]
  },
  "is_active": true,
  "permissions": [
    {"group_name": "standard-users", "permission_level": "execute"},
    {"group_name": "admin-users", "permission_level": "execute"}
  ]
}
