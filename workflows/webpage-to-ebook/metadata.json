{
  "slug": "webpage-to-ebook",
  "name": "Webpage to EPUB",
  "description": "Convert the current webpage to an EPUB ebook file",
  "category": "text",

  "workflow_type": "tool",
  "output_action": "download_file",
  "timeout_seconds": 60,

  "recipe": {
    "collect": ["page_html"]
  },
  "tool": {
    "name": "Webpage to EPUB Converter",
    "tool_type": "ar_plugin",
    "endpoint_url": "http://ancroo-runner:8000/convert/webpage-to-ebook",
    "http_method": "POST",
    "headers": {"Content-Type": "application/json"},
    "payload_template": "{\"html\": \"{{ html }}\", \"title\": \"{{ title }}\", \"url\": \"{{ url }}\"}",
    "response_mapping": "$.result",
    "timeout": 60
  }
}
