{
  "slug": "html-to-markdown",
  "name": "HTML to Markdown",
  "description": "Convert selected HTML to clean Markdown using Ancroo Runner",
  "category": "text",

  "workflow_type": "tool",
  "output_action": "clipboard",
  "demo_url": "demo.html",

  "recipe": {
    "collect": ["text_selection"]
  },
  "tool": {
    "name": "HTML to Markdown Converter",
    "tool_type": "ar_plugin",
    "endpoint_url": "http://ancroo-runner:8000/convert/html-to-markdown",
    "http_method": "POST",
    "headers": {"Content-Type": "application/json"},
    "payload_template": "{\"html\": \"{{ html or text }}\"}",
    "response_mapping": "$.result",
    "timeout": 30
  }
}
