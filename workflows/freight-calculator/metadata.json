{
  "slug": "freight-calculator",
  "name": "Freight Cost Calculator",
  "description": "Calculates estimated freight cost based on weight, destination zone, and package count",
  "category": "automation",
  "is_example": true,

  "workflow_type": "tool",
  "output_action": "fill_fields",
  "demo_url": "demo.html",

  "recipe": {
    "collect": ["form_fields", "page_context"],
    "form_fields": [
      {"name": "weight_kg", "selector": "#field-weight, input[name='weight']"},
      {"name": "zone",      "selector": "#field-zone, select[name='zone'], input[name='zone']"},
      {"name": "packages",  "selector": "#field-packages, input[name='packages']"}
    ],
    "output_fields": [
      {"name": "freight_cost", "selector": "#field-result, input[name='result']"}
    ]
  },
  "tool": {
    "name": "Freight Calculator → Ancroo",
    "tool_type": "n8n_webhook",
    "n8n_workflow_name": "Freight Calculator → Ancroo"
  }
}
