{
  "slug": "name-formatter",
  "name": "Name Formatter",
  "description": "Reads name and email fields from a form, sends them to n8n for formatting, and returns a greeting",
  "category": "automation",
  "is_example": true,

  "workflow_type": "tool",
  "output_action": "notification",
  "demo_url": "demo.html",

  "recipe": {
    "collect": ["form_fields", "page_context"],
    "form_fields": [
      {"name": "first_name", "selector": "#field-first-name, input[name='first_name'], input[name='firstname']"},
      {"name": "last_name",  "selector": "#field-last-name, input[name='last_name'], input[name='lastname']"},
      {"name": "email",      "selector": "#field-email, input[name='email'], input[type='email']"}
    ]
  },
  "tool": {
    "name": "Name Formatter → Ancroo",
    "tool_type": "n8n_webhook",
    "n8n_workflow_name": "Name Formatter → Ancroo"
  }
}
