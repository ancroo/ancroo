{
  "slug": "contact-form-capture",
  "name": "Contact Form Capture",
  "description": "Reads contact form fields from the current page and forwards them to n8n for processing",
  "category": "automation",
  "is_example": true,

  "workflow_type": "workflow_trigger",
  "execution_type": "tool",
  "input_type": "form",
  "output_type": "notification",
  "output_action": "show_notification",
  "input_sources": ["form_fields", "page_context"],

  "form_fields": [
    {"name": "name",     "selector": "#field-name, input[name='name'], input[name='fullname']"},
    {"name": "email",    "selector": "#field-email, input[name='email'], input[type='email']"},
    {"name": "subject",  "selector": "#field-subject, input[name='subject']"},
    {"name": "category", "selector": "#field-category, select[name='category']"},
    {"name": "message",  "selector": "#field-message, textarea[name='message'], textarea[name='body']"}
  ],

  "requires": ["n8n"],
  "n8n_workflow_name": "Contact Form \u2192 Ancroo"
}
